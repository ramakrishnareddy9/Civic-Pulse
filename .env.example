# CivicPulse Environment Variables Template
# Copy this file to .env and fill in your values

# Database
DB_USERNAME=civicadmin
DB_PASSWORD=civicpass

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-256-bit-secret-key-here-replace-with-strong-random-value
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Mail (optional for notifications)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# File Storage
UPLOAD_DIR=./uploads
FILE_BASE_URL=http://localhost:8080/static

# Admin seed account
ADMIN_EMAIL=admin@civicpulse.gov.in
ADMIN_PASSWORD=Admin@123
